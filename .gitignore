# Secrets — never commit
secret.yaml

# Claude Code per-user settings (project-level .claude/settings.json IS committed)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Notebooks
.ipynb_checkpoints/

# Lean sample data at workspace root (~225MB, regenerable via `lean data download`).
# Leading slash so the pattern only matches /data/ and NOT conquest/data/ (Python pkg).
# Also matches the worktree-level `data` symlink that points at the workspace data dir.
/data/
/data

# Conquest sync artifacts (generated by scripts/sync_to_lean.py before any lean cloud push)
cstability/conquest/
cgrowth/conquest/
# chybrid (formerly cf) + ctactical (formerly ctactical_v2) — renamed 2026-06-09, PR #48
chybrid/conquest/
ctactical/conquest/
# legacy paths kept so older worktrees/checkouts still ignore their copies:
cf/conquest/
ctactical_v2/conquest/
cstag_research/conquest/
cstag_voltgt_combined/conquest/
surge/conquest/
ARCHIVED/cresearch/conquest/
combined_v2/conquest/
conquest_options/conquest/
# combined_v3/conquest/ removed — combined_v3 was archived 2026-05-21
# to ARCHIVED/combined_v3/ after the full PIT 2008-2026 backtest showed
# it failed strict-Pareto vs combined_v2 + cstag_v2 (see SHELVED.md inside)
# cresearch ML models (pickled artifacts; train locally per Phase 9 spec)
ARCHIVED/cresearch/ml/models/
# Surviving cspec sync targets (cspec_v17_lev_volgate, cspec_v20_news, cspec_insider)
cspec_*/conquest/

# IDE noise inside archived projects
archive/projects/*/.vscode/

# Local Lean Object Store signals (generated by scripts/classify_regime.py + compute_vol.py)
# Also matches the worktree-level `storage` symlink that points at the workspace storage dir.
storage/conquest/
/storage
# Exception: surgically un-ignore JUST the BT reference equity curve used by the
# daily reconcile workflow. Pattern is verbose because git requires each
# parent path-segment to be re-enabled, and siblings at each level explicitly
# re-excluded so we don't accidentally track unrelated CSVs/JSONs.
# Refresh BT via scripts/fetch_cloud_backtest.py + manual git add when it changes.
!storage/
!storage/conquest/
storage/conquest/*
!storage/conquest/lean/
storage/conquest/lean/*
!storage/conquest/lean/combined_v2_50_50_50k_lean_equity.json

# Lean output dirs (created per-backtest)
backtests/
optimizations/
*.log

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/.ropeproject/

# IDE per-user state (IntelliJ / PyCharm)
.idea/

# Env files
.env
.envrc

# Local backup of QC projects archived by scripts/qc_archive_projects.py
# MANIFEST.json is tracked for audit; bulk file copies live only on local disk
ARCHIVED/*
!ARCHIVED/MANIFEST.json
