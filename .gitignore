# Secrets — never commit
secret.yaml

# Claude Code per-user settings
.claude/settings.local.json
.claude/worktrees/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Notebooks
.ipynb_checkpoints/

# Lean sample data at workspace root (regenerable via `lean data download`).
# Leading slash so it matches /data/ and NOT conquest/data/ (the Python package).
/data/
/data

# Conquest sync artifacts — generated by scripts/sync_to_lean.py before a `lean cloud push`
cstability/conquest/
cgrowth/conquest/
chybrid/conquest/

# Local Lean Object Store signals (generated by the refresh pipeline)
storage/conquest/
/storage

# Lean output dirs (created per-backtest)
backtests/
optimizations/
*.log

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Env files
.env
.envrc
